filters:
  - file.inFolder("wiki/entities")
  - file.hasTag("journal")

properties:
  file.name:
    displayName: "期刊"
  issn:
    displayName: "ISSN"
  citescore:
    displayName: "CiteScore"
  h_index:
    displayName: "h-index"
  metrics_updated:
    displayName: "数据更新"

views:
  - type: table
    name: "全部期刊"
    order:
      - citescore DESC
  - type: table
    name: "需更新（>90天）"
    filters:
      - 'metrics_updated < now() - "90 days"'
    order:
      - metrics_updated ASC
